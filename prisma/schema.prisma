// prisma/schema.prisma
// Phase 2 update: adds PasswordResetToken model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  
}

// ── Users ────────────────────────────────────────────────────

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique
  displayName    String    @map("display_name")
  passwordHash   String    @map("password_hash")
  emailVerified  Boolean   @default(false) @map("email_verified")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  sessions            ExamSession[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

// ── Password Reset Tokens ─────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ── Courses ──────────────────────────────────────────────────

model Course {
  id            String   @id
  code          String
  name          String
  moduleCount   Int      @map("module_count")
  questionCount Int      @default(200) @map("question_count")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  questions Question[]
  sessions  ExamSession[]

  @@map("courses")
}

// ── Questions ────────────────────────────────────────────────

model Question {
  id             String   @id
  courseId       String   @map("course_id")
  moduleNumber   Int      @map("module_number")
  moduleName     String   @map("module_name")
  concept        String
  cognitiveLevel String   @map("cognitive_level")
  stem           String   @db.Text
  optionA        String   @map("option_a") @db.Text
  optionB        String   @map("option_b") @db.Text
  optionC        String   @map("option_c") @db.Text
  optionD        String   @map("option_d") @db.Text
  correctOption  String   @map("correct_option") @db.Char(1)
  rationale      String?  @db.Text
  sourceRef      String?  @map("source_ref")
  imageUrl       String?  @map("image_url")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  course  Course @relation(fields: [courseId], references: [id])
  results SessionQuestionResult[]

  @@index([courseId])
  @@index([courseId, moduleNumber])
  @@map("questions")
}

// ── Exam Sessions ────────────────────────────────────────────

model ExamSession {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  courseId      String        @map("course_id")
  questionIds   String[]      @map("question_ids")
  displayOrders Json          @default("{}") @map("display_orders")
  answers       Json          @default("{}") @map("answers")
  flagged       String[]      @default([])
  status        SessionStatus @default(ACTIVE)
  score         Int?
  percentage    Decimal?      @db.Decimal(5, 2)
  passed        Boolean?
  timeUsedSecs  Int?          @map("time_used_secs")
  startedAt     DateTime      @default(now()) @map("started_at") @db.Timestamptz
  submittedAt   DateTime?     @map("submitted_at") @db.Timestamptz
  auditLog      Json          @default("[]") @map("audit_log")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id])
  results SessionQuestionResult[]

  @@index([userId])
  @@index([userId, courseId])
  @@map("exam_sessions")
}

enum SessionStatus {
  ACTIVE
  SUBMITTED
  EXPIRED
}

// ── Session Question Results ──────────────────────────────────

model SessionQuestionResult {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId      String   @map("session_id") @db.Uuid
  questionId     String   @map("question_id")
  selectedOption String?  @map("selected_option") @db.Char(1)
  isCorrect      Boolean  @map("is_correct")
  timeSpentSecs  Int?     @map("time_spent_secs")
  moduleNumber   Int      @map("module_number")
  cognitiveLevel String   @map("cognitive_level")

  session  ExamSession @relation(fields: [sessionId], references: [id])
  question Question    @relation(fields: [questionId], references: [id])

  @@index([sessionId])
  @@index([questionId])
  @@map("session_question_results")
}
